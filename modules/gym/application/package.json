{
  "name": "@gym/application",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": "./src/index.ts",
    "./errors/*": "./src/errors/*.errors.ts",
    "./factories/*": "./src/factories/*.factory.ts",
    "./models/*": "./src/models/*.models.ts",
    "./repositories/*": "./src/repositories/*.repository.ts",
    "./services/*": "./src/services/*.service.ts",
    "./use-cases/*": "./src/use-cases/*.use-case.ts"
  },
  "dependencies": {
    "@climbing/application": "workspace:*",
    "effect": "4.0.0-beta.70"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.70",
    "@packages/tsconfig": "workspace:*",
    "@types/node": "^25.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
