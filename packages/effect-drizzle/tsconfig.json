{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@packages/ui/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "drizzle.config.ts"],
  "exclude": ["node_modules", "dist"]
}
