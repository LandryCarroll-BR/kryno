{
  "name": "kryno",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "db:down": "docker compose down",
    "db:generate": "pnpm --filter @workspace/database run db:generate",
    "db:migrate": "pnpm --filter @workspace/database run db:migrate",
    "db:reset": "docker compose exec -T postgres sh -c 'dropdb --if-exists --username \"$POSTGRES_USER\" kryno && createdb --username \"$POSTGRES_USER\" kryno'",
    "db:studio": "pnpm --filter @workspace/database exec drizzle-kit studio --config drizzle.config.ts",
    "db:up": "docker compose up -d postgres",
    "dev": "turbo dev",
    "format": "turbo format",
    "test": "node --test test/*.test.mjs && turbo test",
    "prepare": "effect-language-service patch",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@turbo/gen": "^2.9.18",
    "effect-solutions": "^0.5.3",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=20"
  }
}
