{
  "name": "kryno",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "node --test test/*.test.mjs && turbo test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v",
    "db:auth:generate": "pnpm --filter @auth/infrastructure run db:generate",
    "db:auth:migrate": "pnpm --filter @auth/infrastructure run db:migrate",
    "db:auth:studio": "pnpm --filter @auth/infrastructure run db:studio",
    "db:climbing:generate": "pnpm --filter @climbing/infrastructure run db:generate",
    "db:climbing:migrate": "pnpm --filter @climbing/infrastructure run db:migrate",
    "db:climbing:studio": "pnpm --filter @climbing/infrastructure run db:studio",
    "db:gym:generate": "pnpm --filter @gym/infrastructure run db:generate",
    "db:gym:migrate": "pnpm --filter @gym/infrastructure run db:migrate",
    "db:gym:studio": "pnpm --filter @gym/infrastructure run db:studio",
    "format": "turbo format",
    "prepare": "effect-language-service patch",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@turbo/gen": "^2.9.18",
    "effect-solutions": "^0.5.3",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": ">=24.7.0"
  }
}
